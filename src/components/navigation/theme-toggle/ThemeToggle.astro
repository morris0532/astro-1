---
import { Icon as AstroIcon } from "astro-icon/components";

const { class: className, ...htmlAttributes } = Astro.props;
---

<button
  type="button"
  class:list={["theme-toggle", className]}
  aria-label="Toggle dark mode"
  {...htmlAttributes}
>
  <span class="theme-toggle-icon theme-toggle-sun">
    <AstroIcon
      name="sun"
      is:inline
    />
  </span>
  <span class="theme-toggle-icon theme-toggle-moon">
    <AstroIcon
      name="moon"
      is:inline
    />
  </span>
</button>

<script>
  import { onPageLoad } from "@component-utils/onPageLoad";

  function initThemeToggle() {
    const buttons = document.querySelectorAll<HTMLButtonElement>(".theme-toggle");
    const defaultTheme = document.documentElement.getAttribute("data-default-theme") || "light";

    function getTheme(): string {
      return document.documentElement.getAttribute("data-theme") || "light";
    }

    function setTheme(theme: string) {
      document.documentElement.setAttribute("data-theme", theme);
      localStorage.setItem("theme", theme);
      if (theme !== defaultTheme) {
        document.documentElement.setAttribute("data-theme-toggled", "");
      } else {
        document.documentElement.removeAttribute("data-theme-toggled");
      }
      buttons.forEach((btn) => {
        btn.setAttribute(
          "aria-label",
          theme === "dark" ? "Switch to light mode" : "Switch to dark mode"
        );
      });
    }

    buttons.forEach((btn) => {
      btn.setAttribute(
        "aria-label",
        getTheme() === "dark" ? "Switch to light mode" : "Switch to dark mode"
      );

      btn.addEventListener("click", () => {
        setTheme(getTheme() === "dark" ? "light" : "dark");
      });
    });

    matchMedia("(prefers-color-scheme: dark)").addEventListener("change", (e) => {
      if (!localStorage.getItem("theme")) {
        setTheme(e.matches ? "dark" : "light");
      }
    });
  }

  onPageLoad(initThemeToggle);

  document.addEventListener("astro:before-swap", (e: any) => {
    const stored = localStorage.getItem("theme");
    const theme = stored || (matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
    const newDefault = e.newDocument.documentElement.getAttribute("data-theme") || "light";
    e.newDocument.documentElement.setAttribute("data-default-theme", newDefault);
    e.newDocument.documentElement.setAttribute("data-theme", theme);
    if (theme !== newDefault) {
      e.newDocument.documentElement.setAttribute("data-theme-toggled", "");
    }
  });
</script>

<style is:global>
  @layer components {
    .theme-toggle {
      align-items: center;
      background: transparent;
      border: none;
      border-radius: var(--radius-xs);
      color: var(--color-text-strong);
      cursor: pointer;
      display: inline-flex;
      flex-shrink: 0;
      font-size: var(--font-size-xl);
      justify-content: center;
      line-height: 0;
      padding: var(--spacing-em-xs);
      transition-duration: var(--animation-normal);
      transition-property: background-color, color;
      transition-timing-function: ease-in-out;

      &:hover {
        background-color: var(--color-state-hover);
      }

      &:focus-visible {
        box-shadow: 0 0 2px 2px var(--color-focus-ring) inset;
        outline: none;
      }

      svg {
        height: 1em;
        width: 1em;
      }
    }

    .theme-toggle-icon {
      display: none;
      line-height: 0;
    }

    :root[data-theme="light"] .theme-toggle-moon {
      display: block;
    }

    :root[data-theme="dark"] .theme-toggle-sun {
      display: block;
    }
  }
</style>
