---
import CustomSection from "@builders/custom-section/CustomSection.astro";
import Testimonial from "@core-elements/testimonial/Testimonial.astro";

const {
  id = "",
  text = "",
  authorName = "",
  authorDescription = "",
  authorImage = "",
  sectionLabel,
  paddingVertical = "sm",
  paddingHorizontal = "lg",
  maxContentWidth = "2xl",
  colorScheme = "inherit",
  backgroundColor,
  background,
  class: className,
  useDefaultEditableBinding = false,
  _component,
  ...htmlAttributes
} = Astro.props;
---

<CustomSection
  {...htmlAttributes}
  class:list={["testimonial-section-container", className]}
  label={sectionLabel}
  maxContentWidth={maxContentWidth}
  paddingHorizontal={paddingHorizontal}
  paddingVertical={paddingVertical}
  colorScheme={colorScheme}
  backgroundColor=""
  background={background}
  id={id}
  useDefaultEditableBinding={useDefaultEditableBinding}
>
  <CustomSection
    class:list={["testimonial-section", className]}
    maxContentWidth=""
    paddingHorizontal="2xl"
    paddingVertical="2xl"
    colorScheme={colorScheme}
    backgroundColor={backgroundColor}
  >
    <Testimonial
      text={text}
      authorName={authorName}
      authorDescription={authorDescription}
      authorImage={authorImage}
      alignmentHorizontal="start"
      data-prop="text"
      data-prop-author-name="authorName"
      data-prop-author-description="authorDescription"
    />
  </CustomSection>
</CustomSection>

<style is:global>
  @layer page-sections {
    .testimonial-section {
      border-radius: var(--radius-md);
      overflow: hidden;
    }
  }
</style>
